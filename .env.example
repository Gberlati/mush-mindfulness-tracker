ADMIN_USERNAME=admin
# Generate with: pnpm run hash-admin-password mindful-admin
# For local development only, ADMIN_PASSWORD can be used instead of ADMIN_PASSWORD_HASH.
ADMIN_PASSWORD=mindful-admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
SESSION_HASH_SECRET=replace-with-a-long-random-secret

# Optional Supabase production persistence.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Vercel Blob image storage. Local development falls back to public/uploads.
BLOB_READ_WRITE_TOKEN=
